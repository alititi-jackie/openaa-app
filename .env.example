# Local development example:
# NEXT_PUBLIC_SITE_URL=http://localhost:3000
# NEXT_PUBLIC_PRIMARY_SEO_URL=https://openaa.com
# NEXT_PUBLIC_CANONICAL_URL=https://openaa.com
# NEXT_PUBLIC_APP_ENV=development
# NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-local-anon-key
# SUPABASE_SERVICE_ROLE_KEY=your-local-service-role-key

# Vercel production example:
NEXT_PUBLIC_SITE_URL=https://openaa.com
NEXT_PUBLIC_PRIMARY_SEO_URL=https://openaa.com
NEXT_PUBLIC_CANONICAL_URL=https://openaa.com
NEXT_PUBLIC_APP_ENV=production
NEXT_PUBLIC_SUPABASE_URL=https://your-production-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-production-anon-key
SUPABASE_SERVICE_ROLE_KEY=server-only-production-service-role-key
